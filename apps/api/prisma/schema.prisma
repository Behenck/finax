generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String  @id @default(uuid())
  name         String?
  email        String  @unique
  passwordHash String? @map("password_hash")
  avatarUrl    String? @map("avatar_url")

  emailVerifiedAt DateTime? @map("email_verified_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tokens              Token[]
  accounts            Account[]
  invites             Invite[]
  member_on           Member[]
  refreshTokens       RefreshToken[]
  owns_organizations  Organization[]
  createdTransactions Transaction[]  @relation("TransactionCreatedBy")
  employees           Employee[]
  recurrencesCreated  Recurrence[]   @relation("RecurrenceCreatedBy")
  supervisedPartners  Partner[]      @relation("PartnerSupervisor")
  linkedPartners      Partner[]      @relation("PartnerUser")

  @@map("users")
}

enum TokenType {
  PASSWORD_RECOVER
  EMAIL_VERIFICATION
}

enum RefreshTokenStatus {
  ACTIVE
  REVOKED
}

model Token {
  id        String    @id @default(uuid())
  type      TokenType
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user   User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  @@index([userId, type])
  @@map("tokens")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String? @map("user_id")

  @@map("refresh_tokens")
}

enum AccountProvider {
  GITHUB
  GOOGLE
}

model Account {
  id                String          @id @default(uuid())
  provider          AccountProvider
  providerAccountId String          @unique @map("provider_account_id")
  userId            String          @map("user_id")
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

enum Role {
  ADMIN
  MEMBER
}

enum InviteType {
  EMAIL
  LINK
}

model Invite {
  id             String       @id @default(uuid())
  email          String?
  role           Role
  type           InviteType   @default(EMAIL)
  expiresAt      DateTime?
  createdAt      DateTime     @default(now()) @map("created_at")
  author         User?        @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorId       String?      @map("author_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String       @map("organization_id")

  @@unique([email, organizationId])
  @@index([email])
  @@map("invites")
}

model Member {
  id             String       @id @default(uuid())
  role           Role         @default(MEMBER)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String       @map("organization_id")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String       @map("user_id")

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("members")
}

model Organization {
  id                       String   @id @default(uuid())
  name                     String
  slug                     String   @unique
  domain                   String?  @unique
  shouldAttachUserByDomain Boolean  @default(false) @map("should_attach_user_by_domain")
  avatarUrl                String?  @map("avatar_url")
  ownerId                  String   @map("owner_id")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")
  owner                    User?    @relation(fields: [ownerId], references: [id])

  invites      Invite[]
  members      Member[]
  categories   Category[]
  companies    Company[]
  transactions Transaction[]
  costCenters  CostCenter[]
  employees    Employee[]
  recurrences  Recurrence[]
  customers    Customer[]

  @@index([slug])
  @@map("organizations")
}

model Company {
  id             String @id @default(uuid())
  name           String
  organizationId String @map("organization_id")

  createdAt DateTime @default(now()) @map("created_at")

  organization Organization  @relation(fields: [organizationId], references: [id])
  units        Unit[]
  transactions Transaction[]
  employees    Employee[]
  recurrences  Recurrence[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("companies")
}

model Unit {
  id        String @id @default(uuid())
  name      String
  companyId String @map("company_id")

  createdAt DateTime @default(now()) @map("created_at")

  company      Company       @relation(fields: [companyId], references: [id])
  transactions Transaction[]
  recurrences  Recurrence[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("units")
}

model Category {
  id             String          @id @default(uuid())
  name           String
  code           String?
  color          String
  icon           String
  type           TransactionType
  organizationId String?         @map("organization_id")
  parentId       String?         @map("parent_id")
  createdAt      DateTime        @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id])

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")

  transactions     Transaction[]
  transactionItens TransactionItem[]
  recurrences      Recurrence[]

  @@unique([organizationId, parentId, name])
  @@index([organizationId])
  @@index([parentId])
  @@map("categories")
}

model CostCenter {
  id             String @id @default(uuid())
  name           String
  organizationId String @map("organization_id")

  createdAt DateTime @default(now()) @map("created_at")

  organization Organization  @relation(fields: [organizationId], references: [id])
  transactions Transaction[]
  recurrences  Recurrence[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("cost_centers")
}

model Employee {
  id             String  @id @default(uuid())
  name           String
  department     String?
  email          String
  role           String?
  userId         String? @map("user_id")
  organizationId String
  companyId      String

  createdAt DateTime @default(now()) @map("created_at")

  user         User?         @relation(fields: [userId], references: [id])
  organization Organization  @relation(fields: [organizationId], references: [id])
  company      Company       @relation(fields: [companyId], references: [id])
  transactions Transaction[]

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([companyId])
  @@map("employees")
}

enum CustomerPersonType {
  PF
  PJ
}

enum CustomerDocumentType {
  CPF
  CNPJ
  RG
  IE
  PASSPORT
  OTHER
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

model Customer {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")

  personType CustomerPersonType @default(PF) @map("person_type")
  name       String

  documentType   CustomerDocumentType @map("document_type")
  documentNumber String               @map("document_number")

  email  String?
  phone  String?
  status CustomerStatus @default(ACTIVE)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  customerPF   CustomerPF?
  customerPJ   CustomerPJ?

  @@unique([organizationId, documentType, documentNumber])
  @@index([organizationId])
  @@map("customers")
}

model CustomerPF {
  id             String @id @default(uuid())
  customerId     String @unique @map("customer_id")
  organizationId String @map("organization_id")

  birthDate  DateTime? @map("birth_date")
  motherName String?   @map("mother_name")
  fatherName String?   @map("father_name")

  // “salário/renda”: escolha um termo e mantenha 1 só.
  monthlyIncome Int? @map("monthly_income")

  placeOfBirth String? @map("place_of_birth") // naturalidade
  profession   String? @map("profession") // atividade profissional
  naturality   String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("customer_pf")
}

model CustomerPJ {
  id             String @id @default(uuid())
  customerId     String @unique @map("customer_id")
  organizationId String @map("organization_id")

  tradeName             String? @map("trade_name") // nome fantasia
  legalName             String? @map("legal_name") // razão social (se preferir não usar Customer.name)
  stateRegistration     String? @map("state_registration") // IE
  municipalRegistration String? @map("municipal_registration") // IM

  // Exemplo de campos comuns de PJ (ajuste ao seu caso):
  foundationDate   DateTime? @map("foundation_date")
  businessActivity String?   @map("business_activity") // CNAE/atividade (pode virar tabela depois)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("customer_pj")
}

enum PartnerStatus {
  ACTIVE
  INACTIVE
}

enum PartnerDocumentType {
  CPF
  CNPJ
}

model Partner {
  id String @id @default(uuid())

  name  String
  email String
  phone String

  documentType PartnerDocumentType
  document     String

  companyName String @map("company_name")

  street       String?
  number       String?
  complement   String?
  neighborhood String?
  city         String?
  state        String
  zipCode      String?
  country      String  @default("BR")

  userId       String? @map("user_id")
  supervisorId String? @map("supervisor_id")

  status PartnerStatus @default(ACTIVE)

  organizationId String @map("organization_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  supervisor User? @relation("PartnerSupervisor", fields: [supervisorId], references: [id], onDelete: SetNull)
  user       User? @relation("PartnerUser", fields: [userId], references: [id], onDelete: SetNull)

  @@unique([organizationId, email])
  @@unique([organizationId, document])
  @@index([organizationId])
  @@index([organizationId, status])
  @@map("partners")
}

enum TransactionType {
  INCOME
  OUTCOME
}

enum TransactionStatus {
  PENDING
  PAID
  CANCELED
}

enum TransactionNature {
  FIXED
  VARIABLE
}

model Transaction {
  id                   String            @id @default(uuid())
  code                 String
  description          String
  totalAmount          Int               @map("total_amount")
  type                 TransactionType
  status               TransactionStatus
  nature               TransactionNature
  dueDate              DateTime          @map("due_date")
  expectedPaymentDate  DateTime          @map("expected_payment_date")
  paymentDate          DateTime?         @map("payment_date")
  costCenterId         String            @map("cost_center_id")
  organizationId       String            @map("organization_id")
  companyId            String            @map("company_id")
  unitId               String?           @map("unit_id")
  createdById          String            @map("created_by_id")
  refundedByEmployeeId String?           @map("refunded_by_employee_id")
  categoryId           String            @map("category_id")
  notes                String?
  parentId             String?           @map("parent_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  createdBy          User              @relation("TransactionCreatedBy", fields: [createdById], references: [id])
  refundedByEmployee Employee?         @relation(fields: [refundedByEmployeeId], references: [id])
  costCenter         CostCenter        @relation(fields: [costCenterId], references: [id])
  organization       Organization      @relation(fields: [organizationId], references: [id])
  category           Category          @relation(fields: [categoryId], references: [id])
  company            Company           @relation(fields: [companyId], references: [id])
  unit               Unit?             @relation(fields: [unitId], references: [id])
  transactionItens   TransactionItem[]
  parent             Transaction?      @relation("TransactionTree", fields: [parentId], references: [id])
  children           Transaction[]     @relation("TransactionTree")
  userId             String?

  @@index([organizationId, companyId])
  @@index([companyId, unitId])
  @@index([organizationId, dueDate])
  @@index([organizationId, type])
  @@index([organizationId, status])
  @@index([categoryId])
  @@index([createdById])
  @@index([refundedByEmployeeId])
  @@map("transactions")
}

model TransactionItem {
  id            String @id @default(uuid())
  description   String
  transactionId String @map("transaction_id")
  amount        Int
  categoryId    String @map("category_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  transaction Transaction @relation(fields: [transactionId], references: [id])
  category    Category    @relation(fields: [categoryId], references: [id])

  @@index([transactionId])
  @@index([categoryId])
  @@map("transaction_itens")
}

enum RecurrenceDayType {
  CALENDAR_DAY // dia normal: 1..31
  BUSINESS_DAY // n-ésimo dia útil do mês
}

enum RecurrenceAdjustment {
  NONE
  NEXT_BUSINESS_DAY
  PREVIOUS_BUSINESS_DAY
}

enum RecurrenceStatus {
  ACTIVE
  PAUSED
}

model Recurrence {
  id          String          @id @default(uuid())
  description String
  type        TransactionType
  totalAmount Int             @map("total_amount")

  companyId    String  @map("company_id")
  unitId       String? @map("unit_id")
  categoryId   String  @map("category_id")
  costCenterId String  @map("cost_center_id")

  interval Int              @map("interval")
  status   RecurrenceStatus @default(ACTIVE)

  startDate DateTime  @map("start_date")
  endDate   DateTime? @map("end_date")

  executionDay     Int                  @map("execution_day")
  executionDayType RecurrenceDayType    @default(CALENDAR_DAY) @map("execution_day_type")
  adjustmentRule   RecurrenceAdjustment @default(NONE) @map("adjustment_rule")

  lastRunAt DateTime? @map("last_run_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  createdById    String @map("created_by_id")
  organizationId String @map("organization_id")

  createdBy    User         @relation("RecurrenceCreatedBy", fields: [createdById], references: [id])
  costCenter   CostCenter   @relation(fields: [costCenterId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  category     Category     @relation(fields: [categoryId], references: [id])
  company      Company      @relation(fields: [companyId], references: [id])
  unit         Unit?        @relation(fields: [unitId], references: [id])

  @@index([status, startDate, endDate, lastRunAt]) // 🚀 scheduler
  @@index([companyId, status]) // 📊 filtros
  @@index([costCenterId])
  @@index([companyId])
  @@index([unitId])
  @@index([executionDayType, executionDay])
  @@index([interval, executionDayType])
  @@map("recurrences")
}
