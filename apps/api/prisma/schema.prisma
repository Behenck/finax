generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String  @id @default(uuid())
  name         String?
  email        String  @unique
  passwordHash String? @map("password_hash")
  avatarUrl    String? @map("avatar_url")

  emailVerifiedAt DateTime? @map("email_verified_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tokens              Token[]
  accounts            Account[]
  invites             Invite[]
  member_on           Member[]
  refreshTokens       RefreshToken[]
  owns_organizations  Organization[]
  createdTransactions Transaction[]  @relation("TransactionCreatedBy")
  employees           Employee[]
  recurrencesCreated  Recurrence[]   @relation("RecurrenceCreatedBy")
  createdSales        Sale[]         @relation("SaleCreatedBy")
  saleHistoryEvents   SaleHistoryEvent[] @relation("SaleHistoryActor")
  saleImportTemplates SaleImportTemplate[] @relation("SaleImportTemplateCreatedBy")
  saleImportAudits    SaleImportAudit[]    @relation("SaleImportAuditActor")
  supervisedPartners  Partner[]      @relation("PartnerSupervisor")
  linkedPartners      Partner[]      @relation("PartnerUser")
  linkedSellers       Seller[]       @relation("SellerUser")
  permissionAuditLogs PermissionAuditLog[] @relation("PermissionAuditActor")

  @@map("users")
}

enum TokenType {
  PASSWORD_RECOVER
  EMAIL_VERIFICATION
}

enum RefreshTokenStatus {
  ACTIVE
  REVOKED
}

model Token {
  id        String    @id @default(uuid())
  type      TokenType
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user   User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  @@index([userId, type])
  @@map("tokens")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String? @map("user_id")

  @@map("refresh_tokens")
}

enum AccountProvider {
  GITHUB
  GOOGLE
}

model Account {
  id                String          @id @default(uuid())
  provider          AccountProvider
  providerAccountId String          @unique @map("provider_account_id")
  userId            String          @map("user_id")
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

enum Role {
  ADMIN
  MEMBER
  SUPERVISOR
  SELLER
  PARTNER
}

enum MemberDataScope {
  LINKED_ONLY
  COMPANY_ONLY
  ORGANIZATION_ALL
}

enum PermissionOverrideEffect {
  ALLOW
  DENY
}

enum PermissionAuditChangeType {
  ROLE_PRESET_REPLACED
  MEMBER_OVERRIDE_REPLACED
}

enum InviteType {
  EMAIL
  LINK
}

model Invite {
  id             String       @id @default(uuid())
  email          String?
  role           Role
  type           InviteType   @default(EMAIL)
  expiresAt      DateTime?
  createdAt      DateTime     @default(now()) @map("created_at")
  author         User?        @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorId       String?      @map("author_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String       @map("organization_id")

  @@unique([email, organizationId])
  @@index([email])
  @@map("invites")
}

model Member {
  id                    String                @id @default(uuid())
  role                  Role                  @default(MEMBER)
  customersScope        MemberDataScope       @default(ORGANIZATION_ALL) @map("customers_scope")
  salesScope            MemberDataScope       @default(ORGANIZATION_ALL) @map("sales_scope")
  commissionsScope      MemberDataScope       @default(ORGANIZATION_ALL) @map("commissions_scope")
  partnersScope         MemberDataScope       @default(ORGANIZATION_ALL) @map("partners_scope")
  organization          Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId        String                @map("organization_id")
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                String                @map("user_id")
  memberCompanyAccesses MemberCompanyAccess[]
  productCommissions    ProductCommission[]   @relation("ProductCommissionRecipientSupervisor")
  saleCommissions       SaleCommission[]      @relation("SaleCommissionBeneficiarySupervisor")
  permissionOverrides   MemberPermissionOverride[]
  permissionAuditTargets PermissionAuditLog[] @relation("PermissionAuditTargetMember")

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("members")
}

model MemberCompanyAccess {
  id             String  @id @default(uuid())
  memberId       String  @map("member_id")
  companyId      String  @map("company_id")
  unitId         String? @map("unit_id")
  organizationId String  @map("organization_id")

  createdAt DateTime @default(now()) @map("created_at")

  member       Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  unit         Unit?        @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([memberId, companyId, unitId])
  @@index([memberId])
  @@index([companyId])
  @@index([unitId])
  @@map("member_company_access")
}

model Organization {
  id                       String   @id @default(uuid())
  name                     String
  slug                     String   @unique
  domain                   String?  @unique
  shouldAttachUserByDomain Boolean  @default(false) @map("should_attach_user_by_domain")
  enableSalesTransactionsSync Boolean @default(false) @map("enable_sales_transactions_sync")
  avatarUrl                String?  @map("avatar_url")
  ownerId                  String   @map("owner_id")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")
  owner                    User?    @relation(fields: [ownerId], references: [id])

  invites               Invite[]
  members               Member[]
  categories            Category[]
  companies             Company[]
  transactions          Transaction[]
  costCenters           CostCenter[]
  employees             Employee[]
  recurrences           Recurrence[]
  customers             Customer[]
  partners              Partner[]
  sellers               Seller[]
  products              Product[]
  sales                 Sale[]
  saleHistoryEvents     SaleHistoryEvent[]
  saleImportTemplates   SaleImportTemplate[]
  saleImportAudits      SaleImportAudit[]
  memberCompanyAccesses MemberCompanyAccess[]
  rolePermissions       OrganizationRolePermission[]
  memberPermissionOverrides MemberPermissionOverride[]
  permissionAuditLogs   PermissionAuditLog[]

  @@index([slug])
  @@map("organizations")
}

model Permission {
  id          String  @id @default(uuid())
  key         String  @unique
  module      String
  action      String
  description String?
  isActive    Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  rolePermissions   OrganizationRolePermission[]
  memberOverrides   MemberPermissionOverride[]

  @@index([module])
  @@index([isActive])
  @@map("permissions")
}

model OrganizationRolePermission {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")
  role           Role
  permissionId   String @map("permission_id")
  allowed        Boolean @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  permission   Permission   @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([organizationId, role, permissionId])
  @@index([organizationId, role])
  @@index([permissionId])
  @@map("organization_role_permissions")
}

model MemberPermissionOverride {
  id             String @id @default(uuid())
  memberId       String @map("member_id")
  organizationId String @map("organization_id")
  permissionId   String @map("permission_id")
  effect         PermissionOverrideEffect

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  member       Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  permission   Permission   @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([memberId, permissionId])
  @@index([organizationId, memberId])
  @@index([permissionId])
  @@map("member_permission_overrides")
}

model PermissionAuditLog {
  id             String                    @id @default(uuid())
  organizationId String                    @map("organization_id")
  actorUserId    String                    @map("actor_user_id")
  targetMemberId String?                   @map("target_member_id")
  targetRole     Role?                     @map("target_role")
  changeType     PermissionAuditChangeType @map("change_type")
  before         Json
  after          Json

  createdAt DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorUser    User         @relation("PermissionAuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  targetMember Member?      @relation("PermissionAuditTargetMember", fields: [targetMemberId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([actorUserId])
  @@index([targetMemberId])
  @@map("permission_audit_logs")
}

model Company {
  id             String @id @default(uuid())
  name           String
  cnpj           String?
  organizationId String @map("organization_id")

  createdAt DateTime @default(now()) @map("created_at")

  organization                        Organization                         @relation(fields: [organizationId], references: [id])
  units                               Unit[]
  transactions                        Transaction[]
  employees                           Employee[]
  recurrences                         Recurrence[]
  sales                               Sale[]
  saleCommissions                     SaleCommission[]                  @relation("SaleCommissionBeneficiaryCompany")
  memberCompanyAccesses               MemberCompanyAccess[]
  productCommissionScenarioConditions ProductCommissionScenarioCondition[] @relation("ProductCommissionConditionCompany")
  productCommissions                  ProductCommission[]                  @relation("ProductCommissionRecipientCompany")

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("companies")
}

model Unit {
  id           String @id @default(uuid())
  name         String
  cnpj         String?
  country      String?
  state        String?
  city         String?
  street       String?
  zipCode      String?
  neighborhood String?
  number       String?
  complement   String?
  companyId    String @map("company_id")

  createdAt DateTime @default(now()) @map("created_at")

  company                             Company                              @relation(fields: [companyId], references: [id])
  transactions                        Transaction[]
  recurrences                         Recurrence[]
  sales                               Sale[]
  saleCommissions                     SaleCommission[]                  @relation("SaleCommissionBeneficiaryUnit")
  memberCompanyAccesses               MemberCompanyAccess[]
  employees                           Employee[]
  productCommissionScenarioConditions ProductCommissionScenarioCondition[] @relation("ProductCommissionConditionUnit")
  productCommissions                  ProductCommission[]                  @relation("ProductCommissionRecipientUnit")

  @@unique([companyId, name])
  @@index([companyId])
  @@map("units")
}

model Category {
  id             String          @id @default(uuid())
  name           String
  code           String?
  color          String
  icon           String
  type           TransactionType
  organizationId String?         @map("organization_id")
  parentId       String?         @map("parent_id")
  createdAt      DateTime        @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id])

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")

  transactions     Transaction[]
  transactionItens TransactionItem[]
  recurrences      Recurrence[]
  salesTransactionProducts Product[] @relation("ProductSalesTransactionCategory")

  @@unique([organizationId, parentId, name])
  @@index([organizationId])
  @@index([parentId])
  @@map("categories")
}

model CostCenter {
  id             String @id @default(uuid())
  name           String
  organizationId String @map("organization_id")

  createdAt DateTime @default(now()) @map("created_at")

  organization Organization  @relation(fields: [organizationId], references: [id])
  transactions Transaction[]
  recurrences  Recurrence[]
  salesTransactionProducts Product[] @relation("ProductSalesTransactionCostCenter")

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("cost_centers")
}

enum EmployeePixKeyType {
  CPF
  CNPJ
  EMAIL
  PHONE
  RANDOM
}

model Employee {
  id             String  @id @default(uuid())
  name           String
  department     String?
  email          String
  phone          String?
  role           String?
  cpf            String?
  pixKeyType     EmployeePixKeyType? @map("pix_key_type")
  pixKey         String?             @map("pix_key")
  paymentNotes   String?             @map("payment_notes")
  street         String?
  number         String?
  complement     String?
  neighborhood   String?
  city           String?
  state          String?
  zipCode        String?             @map("zip_code")
  country        String?
  userId         String? @map("user_id")
  organizationId String
  companyId      String
  unitId         String?

  createdAt DateTime @default(now()) @map("created_at")

  user         User?         @relation(fields: [userId], references: [id])
  organization Organization  @relation(fields: [organizationId], references: [id])
  company      Company       @relation(fields: [companyId], references: [id])
  unit         Unit?         @relation(fields: [unitId], references: [id])
  transactions Transaction[]

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([companyId])
  @@map("employees")
}

enum CustomerPersonType {
  PF
  PJ
}

enum CustomerDocumentType {
  CPF
  CNPJ
  RG
  IE
  PASSPORT
  OTHER
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

enum CustomerResponsibleType {
  SELLER
  PARTNER
}

model Customer {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")

  personType CustomerPersonType @default(PF) @map("person_type")
  name       String

  documentType   CustomerDocumentType @map("document_type")
  documentNumber String               @map("document_number")

  email  String?
  phone  String?
  status CustomerStatus @default(ACTIVE)

  responsibleType CustomerResponsibleType? @map("responsible_type")
  responsibleId   String?                  @map("responsible_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  sales        Sale[]
  customerPF   CustomerPF?
  customerPJ   CustomerPJ?

  @@unique([organizationId, documentType, documentNumber])
  @@index([organizationId])
  @@index([responsibleId])
  @@map("customers")
}

model CustomerPF {
  id             String @id @default(uuid())
  customerId     String @unique @map("customer_id")
  organizationId String @map("organization_id")

  birthDate  DateTime? @map("birth_date")
  motherName String?   @map("mother_name")
  fatherName String?   @map("father_name")

  // “salário/renda”: escolha um termo e mantenha 1 só.
  monthlyIncome Int? @map("monthly_income")

  placeOfBirth String? @map("place_of_birth") // naturalidade
  profession   String? @map("profession") // atividade profissional
  naturality   String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("customer_pf")
}

model CustomerPJ {
  id             String @id @default(uuid())
  customerId     String @unique @map("customer_id")
  organizationId String @map("organization_id")

  tradeName             String? @map("trade_name") // nome fantasia
  legalName             String? @map("legal_name") // razão social (se preferir não usar Customer.name)
  stateRegistration     String? @map("state_registration") // IE
  municipalRegistration String? @map("municipal_registration") // IM

  // Exemplo de campos comuns de PJ (ajuste ao seu caso):
  foundationDate   DateTime? @map("foundation_date")
  businessActivity String?   @map("business_activity") // CNAE/atividade (pode virar tabela depois)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("customer_pj")
}

enum PartnerStatus {
  ACTIVE
  INACTIVE
}

enum PartnerDocumentType {
  CPF
  CNPJ
}

model Partner {
  id String @id @default(uuid())

  name  String
  email String
  phone String

  documentType PartnerDocumentType
  document     String

  companyName String @map("company_name")

  street       String?
  number       String?
  complement   String?
  neighborhood String?
  city         String?
  state        String
  zipCode      String?
  country      String  @default("BR")

  userId       String? @map("user_id")
  supervisorId String? @map("supervisor_id")

  status PartnerStatus @default(ACTIVE)

  organizationId String @map("organization_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  supervisor   User?        @relation("PartnerSupervisor", fields: [supervisorId], references: [id], onDelete: SetNull)
  user         User?        @relation("PartnerUser", fields: [userId], references: [id], onDelete: SetNull)
  organization Organization @relation(fields: [organizationId], references: [id])
  productCommissionScenarioConditions ProductCommissionScenarioCondition[] @relation("ProductCommissionConditionPartner")
  saleCommissions                    SaleCommission[]                  @relation("SaleCommissionBeneficiaryPartner")

  @@unique([organizationId, email])
  @@unique([organizationId, document])
  @@index([organizationId])
  @@index([organizationId, status])
  @@map("partners")
}

enum SellerStatus {
  ACTIVE
  INACTIVE
}

enum SellerDocumentType {
  CPF
  CNPJ
}

model Seller {
  id String @id @default(uuid())

  name  String
  email String
  phone String

  documentType SellerDocumentType
  document     String

  companyName String @map("company_name")

  street       String?
  number       String?
  complement   String?
  neighborhood String?
  city         String?
  state        String
  zipCode      String?
  country      String  @default("BR")

  userId String? @map("user_id")

  status SellerStatus @default(ACTIVE)

  organizationId String @map("organization_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user                                User?                                @relation("SellerUser", fields: [userId], references: [id], onDelete: SetNull)
  organization                        Organization                         @relation(fields: [organizationId], references: [id])
  productCommissionScenarioConditions ProductCommissionScenarioCondition[] @relation("ProductCommissionConditionSeller")
  productCommissions                  ProductCommission[]                  @relation("ProductCommissionRecipientSeller")
  saleCommissions                     SaleCommission[]                     @relation("SaleCommissionBeneficiarySeller")

  @@unique([organizationId, email])
  @@unique([organizationId, document])
  @@index([organizationId])
  @@index([organizationId, status])
  @@map("sellers")
}

model Product {
  id                             String  @id @default(uuid())
  organizationId                 String  @map("organization_id")
  parentId                       String? @map("parent_id")
  name                           String
  description                    String?
  isActive                       Boolean @default(true) @map("is_active")
  sortOrder                      Int     @default(0) @map("sort_order")
  salesTransactionCategoryId     String? @map("sales_transaction_category_id")
  salesTransactionCostCenterId   String? @map("sales_transaction_cost_center_id")
  commissionReversalMode         ProductCommissionReversalMode? @map("commission_reversal_mode")
  commissionReversalTotalPercentage Int? @map("commission_reversal_total_percentage")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization              Organization @relation(fields: [organizationId], references: [id])
  parent                    Product?     @relation("ProductTree", fields: [parentId], references: [id], onDelete: Restrict)
  children                  Product[]    @relation("ProductTree")
  sales                     Sale[]
  saleFields                ProductSaleField[]
  salesTransactionCategory  Category?    @relation("ProductSalesTransactionCategory", fields: [salesTransactionCategoryId], references: [id], onDelete: SetNull)
  salesTransactionCostCenter CostCenter? @relation("ProductSalesTransactionCostCenter", fields: [salesTransactionCostCenterId], references: [id], onDelete: SetNull)

  commissionScenarios ProductCommissionScenario[]
  commissionReversalRules ProductCommissionReversalRule[]

  @@unique([organizationId, parentId, name])
  @@index([organizationId])
  @@index([parentId])
  @@index([organizationId, isActive])
  @@index([salesTransactionCategoryId])
  @@index([salesTransactionCostCenterId])
  @@map("products")
}

enum ProductCommissionReversalMode {
  INSTALLMENT_BY_NUMBER
  TOTAL_PAID_PERCENTAGE
}

model ProductCommissionReversalRule {
  id                String @id @default(uuid())
  productId         String @map("product_id")
  installmentNumber Int    @map("installment_number")
  percentage        Int

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, installmentNumber])
  @@index([productId])
  @@map("product_commission_reversal_rules")
}

enum SaleDynamicFieldType {
  TEXT
  NUMBER
  CURRENCY
  RICH_TEXT
  PHONE
  SELECT
  MULTI_SELECT
  DATE
  DATE_TIME
}

model ProductSaleField {
  id              String               @id @default(uuid())
  productId       String               @map("product_id")
  label           String
  labelNormalized String               @map("label_normalized")
  type            SaleDynamicFieldType
  required        Boolean              @default(false)
  sortOrder       Int                  @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  options ProductSaleFieldOption[]

  @@unique([productId, labelNormalized])
  @@index([productId])
  @@index([productId, sortOrder])
  @@map("product_sale_fields")
}

model ProductSaleFieldOption {
  id              String @id @default(uuid())
  fieldId         String @map("field_id")
  label           String
  labelNormalized String @map("label_normalized")
  isDefault       Boolean @default(false) @map("is_default")
  sortOrder       Int    @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")

  field ProductSaleField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([fieldId, labelNormalized])
  @@index([fieldId])
  @@index([fieldId, sortOrder])
  @@map("product_sale_field_options")
}

enum ProductCommissionScenarioConditionType {
  COMPANY_EQUALS
  PARTNER_EQUALS
  SALE_HAS_COMPANY
  SALE_HAS_PARTNER
  SALE_HAS_SELLER
  SALE_HAS_UNIT
  SALE_UNIT_EQUALS
  SELLER_EQUALS
}

model ProductCommissionScenario {
  id          String  @id @default(uuid())
  productId   String  @map("product_id")
  name        String
  description String?
  isDefault   Boolean @default(false) @map("is_default")
  isActive    Boolean @default(true) @map("is_active")
  sortOrder   Int     @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id])

  conditions  ProductCommissionScenarioCondition[]
  commissions ProductCommission[]

  @@unique([productId, name])
  @@index([productId])
  @@index([productId, isActive, sortOrder])
  @@map("product_commission_scenarios")
}

model ProductCommissionScenarioCondition {
  id         String                                 @id @default(uuid())
  scenarioId String                                 @map("scenario_id")
  type       ProductCommissionScenarioConditionType
  companyId  String?                                @map("company_id")
  partnerId  String?                                @map("partner_id")
  sellerId   String?                                @map("seller_id")
  unitId     String?                                @map("unit_id")
  sortOrder  Int                                    @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")

  scenario ProductCommissionScenario @relation(fields: [scenarioId], references: [id])
  company  Company?                  @relation("ProductCommissionConditionCompany", fields: [companyId], references: [id])
  partner  Partner?                  @relation("ProductCommissionConditionPartner", fields: [partnerId], references: [id])
  seller   Seller?                   @relation("ProductCommissionConditionSeller", fields: [sellerId], references: [id])
  unit     Unit?                     @relation("ProductCommissionConditionUnit", fields: [unitId], references: [id])

  @@index([scenarioId])
  @@index([scenarioId, sortOrder])
  @@index([companyId])
  @@index([partnerId])
  @@index([sellerId])
  @@index([unitId])
  @@map("product_commission_scenario_conditions")
}

enum ProductCommissionRecipientType {
  COMPANY
  UNIT
  SELLER
  PARTNER
  SUPERVISOR
  OTHER
}

enum ProductCommissionCalculationBase {
  SALE_TOTAL
  COMMISSION
}

model ProductCommission {
  id                        String                         @id @default(uuid())
  scenarioId                String                         @map("scenario_id")
  description               String
  recipientType             ProductCommissionRecipientType @map("recipient_type")
  calculationBase           ProductCommissionCalculationBase @default(SALE_TOTAL) @map("calculation_base")
  baseCommissionId          String?                        @map("base_commission_id")
  recipientCompanyId        String?                        @map("recipient_company_id")
  recipientUnitId           String?                        @map("recipient_unit_id")
  recipientSellerId         String?                        @map("recipient_seller_id")
  recipientSupervisorId     String?                        @map("recipient_supervisor_id")
  recipientOtherDescription String?                        @map("recipient_other_description")
  totalPercentage           Int                            @map("total_percentage")
  sortOrder                 Int                            @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  scenario            ProductCommissionScenario      @relation(fields: [scenarioId], references: [id])
  baseCommission      ProductCommission?             @relation("ProductCommissionBaseLink", fields: [baseCommissionId], references: [id], onDelete: SetNull)
  childCommissions    ProductCommission[]            @relation("ProductCommissionBaseLink")
  recipientCompany    Company?                @relation("ProductCommissionRecipientCompany", fields: [recipientCompanyId], references: [id])
  recipientUnit       Unit?                   @relation("ProductCommissionRecipientUnit", fields: [recipientUnitId], references: [id])
  recipientSeller     Seller?                 @relation("ProductCommissionRecipientSeller", fields: [recipientSellerId], references: [id])
  recipientSupervisor Member?                 @relation("ProductCommissionRecipientSupervisor", fields: [recipientSupervisorId], references: [id])
  installments ProductCommissionInstallment[]

  @@index([scenarioId])
  @@index([scenarioId, sortOrder])
  @@index([baseCommissionId])
  @@index([recipientCompanyId])
  @@index([recipientUnitId])
  @@index([recipientSellerId])
  @@index([recipientSupervisorId])
  @@map("product_commissions")
}

model ProductCommissionInstallment {
  id                String @id @default(uuid())
  commissionId      String @map("commission_id")
  installmentNumber Int    @map("installment_number")
  percentage        Int

  createdAt DateTime @default(now()) @map("created_at")

  commission ProductCommission @relation(fields: [commissionId], references: [id])

  @@unique([commissionId, installmentNumber])
  @@index([commissionId])
  @@map("product_commission_installments")
}

enum SaleStatus {
  PENDING
  APPROVED
  COMPLETED
  CANCELED
}

enum SaleResponsibleType {
  SELLER
  PARTNER
}

enum SaleCommissionSourceType {
  PULLED
  MANUAL
}

enum SaleCommissionRecipientType {
  COMPANY
  UNIT
  SELLER
  PARTNER
  SUPERVISOR
  OTHER
}

enum SaleCommissionDirection {
  INCOME
  OUTCOME
}

enum SaleCommissionCalculationBase {
  SALE_TOTAL
  COMMISSION
}

enum SaleCommissionInstallmentStatus {
  PENDING
  PAID
  CANCELED
  REVERSED
}

enum SaleHistoryAction {
  CREATED
  UPDATED
  STATUS_CHANGED
  COMMISSION_INSTALLMENT_UPDATED
  COMMISSION_INSTALLMENT_STATUS_UPDATED
  COMMISSION_INSTALLMENT_DELETED
}

model Sale {
  id String @id @default(uuid())

  organizationId  String              @map("organization_id")
  companyId       String              @map("company_id")
  unitId          String?             @map("unit_id")
  customerId      String              @map("customer_id")
  productId       String              @map("product_id")
  saleDate        DateTime            @map("sale_date") @db.Date
  totalAmount     Int                 @map("total_amount")
  status          SaleStatus          @default(PENDING)
  responsibleType SaleResponsibleType? @map("responsible_type")
  responsibleId   String?              @map("responsible_id")
  notes           String?
  dynamicFieldSchema Json             @default("[]") @map("dynamic_field_schema")
  dynamicFieldValues Json             @default("{}") @map("dynamic_field_values")
  createdById     String              @map("created_by_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  company      Company      @relation(fields: [companyId], references: [id])
  unit         Unit?        @relation(fields: [unitId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])
  product      Product      @relation(fields: [productId], references: [id])
  createdBy    User         @relation("SaleCreatedBy", fields: [createdById], references: [id])
  commissions  SaleCommission[]
  historyEvents SaleHistoryEvent[]
  transaction  Transaction? @relation("SaleTransaction")

  @@index([organizationId, saleDate])
  @@index([organizationId, status])
  @@index([organizationId, companyId])
  @@index([companyId, unitId])
  @@index([customerId])
  @@index([productId])
  @@index([createdById])
  @@index([organizationId, responsibleType, responsibleId])
  @@map("sales")
}

model SaleHistoryEvent {
  id             String            @id @default(uuid())
  saleId         String            @map("sale_id")
  organizationId String            @map("organization_id")
  actorId        String            @map("actor_id")
  action         SaleHistoryAction
  changes        Json

  createdAt DateTime @default(now()) @map("created_at")

  sale         Sale         @relation(fields: [saleId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])
  actor        User         @relation("SaleHistoryActor", fields: [actorId], references: [id])

  @@index([saleId])
  @@index([organizationId, saleId, createdAt])
  @@index([actorId])
  @@map("sale_history_events")
}

model SaleImportTemplate {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")
  name           String
  headerSignature String @map("header_signature")
  mappingJson    Json   @map("mapping_json")
  fixedValuesJson Json  @map("fixed_values_json")
  createdById    String @map("created_by_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("SaleImportTemplateCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  audits       SaleImportAudit[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([organizationId, headerSignature])
  @@index([createdById])
  @@map("sale_import_templates")
}

model SaleImportAudit {
  id             String  @id @default(uuid())
  organizationId String  @map("organization_id")
  actorId        String  @map("actor_id")
  templateId     String? @map("template_id")
  fileType       String  @map("file_type")
  headerSignature String @map("header_signature")
  totalRows      Int     @map("total_rows")
  importedRows   Int     @map("imported_rows")
  failedRows     Int     @map("failed_rows")

  createdAt DateTime @default(now()) @map("created_at")

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor        User              @relation("SaleImportAuditActor", fields: [actorId], references: [id], onDelete: Cascade)
  template     SaleImportTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, createdAt])
  @@index([actorId])
  @@index([templateId])
  @@map("sale_import_audits")
}

model SaleCommission {
  id                    String                    @id @default(uuid())
  saleId                String                    @map("sale_id")
  sourceType            SaleCommissionSourceType  @map("source_type")
  recipientType         SaleCommissionRecipientType @map("recipient_type")
  direction             SaleCommissionDirection   @map("direction")
  calculationBase       SaleCommissionCalculationBase @default(SALE_TOTAL) @map("calculation_base")
  baseCommissionId      String?                   @map("base_commission_id")
  beneficiaryCompanyId  String?                   @map("beneficiary_company_id")
  beneficiaryUnitId     String?                   @map("beneficiary_unit_id")
  beneficiarySellerId   String?                   @map("beneficiary_seller_id")
  beneficiaryPartnerId  String?                   @map("beneficiary_partner_id")
  beneficiarySupervisorId String?                 @map("beneficiary_supervisor_id")
  beneficiaryLabel      String?                   @map("beneficiary_label")
  startDate             DateTime                  @map("start_date") @db.Date
  totalPercentage       Int                       @map("total_percentage")
  sortOrder             Int                       @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sale                 Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  baseCommission       SaleCommission? @relation("SaleCommissionBaseLink", fields: [baseCommissionId], references: [id], onDelete: SetNull)
  childCommissions     SaleCommission[] @relation("SaleCommissionBaseLink")
  beneficiaryCompany   Company? @relation("SaleCommissionBeneficiaryCompany", fields: [beneficiaryCompanyId], references: [id], onDelete: SetNull)
  beneficiaryUnit      Unit?    @relation("SaleCommissionBeneficiaryUnit", fields: [beneficiaryUnitId], references: [id], onDelete: SetNull)
  beneficiarySeller    Seller?  @relation("SaleCommissionBeneficiarySeller", fields: [beneficiarySellerId], references: [id], onDelete: SetNull)
  beneficiaryPartner   Partner? @relation("SaleCommissionBeneficiaryPartner", fields: [beneficiaryPartnerId], references: [id], onDelete: SetNull)
  beneficiarySupervisor Member? @relation("SaleCommissionBeneficiarySupervisor", fields: [beneficiarySupervisorId], references: [id], onDelete: SetNull)
  installments         SaleCommissionInstallment[]

  @@index([saleId])
  @@index([saleId, sortOrder])
  @@index([baseCommissionId])
  @@index([beneficiaryCompanyId])
  @@index([beneficiaryUnitId])
  @@index([beneficiarySellerId])
  @@index([beneficiaryPartnerId])
  @@index([beneficiarySupervisorId])
  @@map("sale_commissions")
}

model SaleCommissionInstallment {
  id                String @id @default(uuid())
  saleCommissionId  String @map("sale_commission_id")
  originInstallmentId String? @map("origin_installment_id")
  installmentNumber Int    @map("installment_number")
  percentage        Int
  amount            Int
  status            SaleCommissionInstallmentStatus @default(PENDING)
  expectedPaymentDate DateTime @map("expected_payment_date") @db.Date
  paymentDate       DateTime? @map("payment_date") @db.Date
  reversedFromStatus SaleCommissionInstallmentStatus? @map("reversed_from_status")
  reversedFromAmount Int? @map("reversed_from_amount")
  reversedFromPaymentDate DateTime? @map("reversed_from_payment_date") @db.Date

  createdAt DateTime @default(now()) @map("created_at")

  saleCommission SaleCommission @relation(fields: [saleCommissionId], references: [id], onDelete: Cascade)
  originInstallment SaleCommissionInstallment? @relation("SaleCommissionInstallmentReversalOrigin", fields: [originInstallmentId], references: [id], onDelete: SetNull)
  reversalInstallments SaleCommissionInstallment[] @relation("SaleCommissionInstallmentReversalOrigin")

  @@index([saleCommissionId, installmentNumber])
  @@index([saleCommissionId])
  @@index([originInstallmentId])
  @@index([saleCommissionId, status])
  @@index([expectedPaymentDate])
  @@map("sale_commission_installments")
}

enum TransactionType {
  INCOME
  OUTCOME
}

enum TransactionStatus {
  PENDING
  PAID
  CANCELED
}

enum TransactionNature {
  FIXED
  VARIABLE
}

model Transaction {
  id                   String            @id @default(uuid())
  code                 String
  description          String
  totalAmount          Int               @map("total_amount")
  type                 TransactionType
  status               TransactionStatus
  nature               TransactionNature
  dueDate              DateTime          @map("due_date")
  expectedPaymentDate  DateTime          @map("expected_payment_date")
  paymentDate          DateTime?         @map("payment_date")
  costCenterId         String            @map("cost_center_id")
  organizationId       String            @map("organization_id")
  companyId            String            @map("company_id")
  unitId               String?           @map("unit_id")
  createdById          String            @map("created_by_id")
  refundedByEmployeeId String?           @map("refunded_by_employee_id")
  categoryId           String            @map("category_id")
  notes                String?
  parentId             String?           @map("parent_id")
  saleId               String?           @unique @map("sale_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  createdBy          User              @relation("TransactionCreatedBy", fields: [createdById], references: [id])
  refundedByEmployee Employee?         @relation(fields: [refundedByEmployeeId], references: [id])
  costCenter         CostCenter        @relation(fields: [costCenterId], references: [id])
  organization       Organization      @relation(fields: [organizationId], references: [id])
  category           Category          @relation(fields: [categoryId], references: [id])
  company            Company           @relation(fields: [companyId], references: [id])
  unit               Unit?             @relation(fields: [unitId], references: [id])
  transactionItens   TransactionItem[]
  parent             Transaction?      @relation("TransactionTree", fields: [parentId], references: [id])
  children           Transaction[]     @relation("TransactionTree")
  userId             String?
  sale               Sale?             @relation("SaleTransaction", fields: [saleId], references: [id], onDelete: SetNull)

  @@index([organizationId, companyId])
  @@index([companyId, unitId])
  @@index([organizationId, dueDate])
  @@index([organizationId, type])
  @@index([organizationId, status])
  @@index([categoryId])
  @@index([createdById])
  @@index([refundedByEmployeeId])
  @@map("transactions")
}

model TransactionItem {
  id            String @id @default(uuid())
  description   String
  transactionId String @map("transaction_id")
  amount        Int
  categoryId    String @map("category_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  transaction Transaction @relation(fields: [transactionId], references: [id])
  category    Category    @relation(fields: [categoryId], references: [id])

  @@index([transactionId])
  @@index([categoryId])
  @@map("transaction_itens")
}

enum RecurrenceDayType {
  CALENDAR_DAY // dia normal: 1..31
  BUSINESS_DAY // n-ésimo dia útil do mês
}

enum RecurrenceAdjustment {
  NONE
  NEXT_BUSINESS_DAY
  PREVIOUS_BUSINESS_DAY
}

enum RecurrenceStatus {
  ACTIVE
  PAUSED
}

model Recurrence {
  id          String          @id @default(uuid())
  description String
  type        TransactionType
  totalAmount Int             @map("total_amount")

  companyId    String  @map("company_id")
  unitId       String? @map("unit_id")
  categoryId   String  @map("category_id")
  costCenterId String  @map("cost_center_id")

  interval Int              @map("interval")
  status   RecurrenceStatus @default(ACTIVE)

  startDate DateTime  @map("start_date")
  endDate   DateTime? @map("end_date")

  executionDay     Int                  @map("execution_day")
  executionDayType RecurrenceDayType    @default(CALENDAR_DAY) @map("execution_day_type")
  adjustmentRule   RecurrenceAdjustment @default(NONE) @map("adjustment_rule")

  lastRunAt DateTime? @map("last_run_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  createdById    String @map("created_by_id")
  organizationId String @map("organization_id")

  createdBy    User         @relation("RecurrenceCreatedBy", fields: [createdById], references: [id])
  costCenter   CostCenter   @relation(fields: [costCenterId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  category     Category     @relation(fields: [categoryId], references: [id])
  company      Company      @relation(fields: [companyId], references: [id])
  unit         Unit?        @relation(fields: [unitId], references: [id])

  @@index([status, startDate, endDate, lastRunAt]) // 🚀 scheduler
  @@index([companyId, status]) // 📊 filtros
  @@index([costCenterId])
  @@index([companyId])
  @@index([unitId])
  @@index([executionDayType, executionDay])
  @@index([interval, executionDayType])
  @@map("recurrences")
}
