NODE_ENV=production
PORT=3333

# Replace HOST_INTERNO_DO_POSTGRES and SENHA_DO_POSTGRES with the values from the Easypanel Postgres service.
DATABASE_URL=postgresql://finax:SENHA_DO_POSTGRES@HOST_INTERNO_DO_POSTGRES:5432/finax?schema=public

# Generate a strong secret before deploying.
JWT_SECRET=GERAR_SEGREDO_FORTE

APP_WEB_URL=https://app.k6ure7.easypanel.host
APP_WEB_URLS=https://app.k6ure7.easypanel.host

# Optional integrations. Fill only if these features are used.
RESEND_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.k6ure7.easypanel.host/sessions/google/callback
